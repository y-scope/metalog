# ========================================
# CLP Service Port Configuration
# ========================================
# Copy this file to .env and customize ports as needed
# Docker Compose will automatically load .env file

# Database Ports
# Note: Only one database (MySQL or MariaDB) runs at a time
MYSQL_PORT=3306
MARIADB_PORT=3306

# Kafka Port
KAFKA_PORT=9092

# MinIO Ports (S3-compatible object storage)
# API port (S3 API)
MINIO_PORT=9000

# Console port (Web UI)
MINIO_CONSOLE_PORT=9001

# ========================================
# Common Port Conflicts and Solutions
# ========================================
#
# Port 9000 conflict (Zscaler, Portainer, SonarQube):
#   MINIO_PORT=9002
#
# Port 3306 conflict (existing MySQL/MariaDB):
#   MYSQL_PORT=3307
#   MARIADB_PORT=3307
#
# Port 9092 conflict (existing Kafka):
#   KAFKA_PORT=9093
#
# ========================================
# Example: Avoid all conflicts
# ========================================
# MYSQL_PORT=3307
# MARIADB_PORT=3307
# KAFKA_PORT=9093
# MINIO_PORT=9002
# MINIO_CONSOLE_PORT=9003
